# Copy to .env and fill in.  The nearest .env (walking up from your working
# directory) is auto-loaded; a real shell environment variable always wins.
#
#   cp .env.example .env

# --- LLM deep-judge (set at least one; Anthropic is preferred when both exist) ---
ANTHROPIC_API_KEY=
OPENAI_API_KEY=

# --- Optional ---
# Higher Semantic Scholar rate limits
# S2_API_KEY=

# Provider / model overrides (otherwise auto-selected from the keys above)
# RHG_JUDGE_PROVIDER=auto          # auto | anthropic | openai
# RHG_JUDGE_MODEL=                 # e.g. claude-sonnet-4-6 or gpt-4.1
# RHG_EMBED_BACKEND=auto           # auto | sentence-transformers | openai | hashing
# RHG_JUDGE=on                     # set to off/0/false to disable the judge

# OpenAlex polite-pool contact (recommended)
# RHG_OPENALEX_MAILTO=you@example.com

# Ground the judge's math-depth mode in a local math-skills repo
# RHG_MATH_SKILLS_PATH=/path/to/math-skills
